{
  "info": {
    "_postman_id": "mb-community-api",
    "name": "Meditation Builder Community API",
    "description": "Community Library REST API — all 10 endpoints with Cognito auth pre-request script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const needsAuth = pm.request.auth && pm.request.auth.type === 'bearer';",
          "if (!needsAuth) { return; }",
          "const now = Math.floor(Date.now() / 1000);",
          "const envToken = pm.environment.get('access_token');",
          "if (envToken) {",
          "  pm.collectionVariables.set('access_token', envToken);",
          "  pm.collectionVariables.set('token_expires_at', String(now + 3600));",
          "  return;",
          "}",
          "const expires = Number(pm.collectionVariables.get('token_expires_at') || 0);",
          "if (pm.collectionVariables.get('access_token') && expires > now + 60) { return; }",
          "console.warn('No access_token — obtain via aws cognito-idp initiate-auth (see docs/E2E_TESTING.md §3.4) and pass --env-var access_token=$TOKEN');"
        ]
      }
    }
  ],
  "variable": [
    { "key": "access_token", "value": "" },
    { "key": "token_expires_at", "value": "0" },
    { "key": "routine_id", "value": "{{seed_routine_id}}" },
    { "key": "published_routine_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Refresh Cognito Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/routines?pageSize=1"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get('access_token');",
                  "if (!token) {",
                  "  pm.execution.skipRequest('Set access_token via aws cognito-idp initiate-auth (E2E_TESTING.md §3.4)');",
                  "}",
                  "pm.collectionVariables.set('access_token', token);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('access_token configured', () => pm.expect(pm.environment.get('access_token')).to.be.a('string').and.not.empty);",
                  "pm.test('API reachable with token', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Routines",
      "item": [
        {
          "name": "GET /routines (browse)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/routines?pageSize=20&sort=newest",
              "host": ["{{base_url}}"],
              "path": ["routines"],
              "query": [
                { "key": "pageSize", "value": "20" },
                { "key": "sort", "value": "newest" },
                { "key": "tag", "value": "focus", "disabled": true },
                { "key": "nextToken", "value": "", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has routines array', () => pm.expect(json.routines).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /routines (publish)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Routine\",\n  \"blocks\": [\n    {\"blockId\": \"b1\", \"type\": \"timer\", \"durationSeconds\": 300, \"label\": \"Breathing\"},\n    {\"blockId\": \"b2\", \"type\": \"bell\", \"soundKey\": \"singing_bowl_c\", \"label\": \"Bell\"}\n  ],\n  \"durationSeconds\": 300,\n  \"userDescription\": \"Created via Postman\"\n}"
            },
            "url": "{{base_url}}/routines"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('routineId returned', () => pm.expect(json.routineId).to.be.a('string'));",
                  "pm.collectionVariables.set('published_routine_id', json.routineId);",
                  "pm.collectionVariables.set('routine_id', json.routineId);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /routines/{id}",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/routines/{{routine_id}}"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('routine_id')) {",
                  "  pm.execution.skipRequest('Set routine_id or run browse/publish first');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has blocks', () => pm.expect(json.blocks).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Social",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('routine_id', pm.environment.get('seed_routine_id'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "item": [
        {
          "name": "POST /routines/{id}/like",
          "request": { "method": "POST", "url": "{{base_url}}/routines/{{routine_id}}/like" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('likeCount present', () => pm.expect(pm.response.json().likeCount).to.be.a('number'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "DELETE /routines/{id}/like",
          "request": { "method": "DELETE", "url": "{{base_url}}/routines/{{routine_id}}/like" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('likeCount present', () => pm.expect(pm.response.json().likeCount).to.be.a('number'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /routines/{id}/import",
          "request": { "method": "POST", "url": "{{base_url}}/routines/{{routine_id}}/import" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('routine payload present', () => pm.expect(json.routine).to.be.an('object'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Discovery",
      "item": [
        {
          "name": "GET /recommendations",
          "request": { "method": "GET", "url": "{{base_url}}/recommendations?limit=10" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('recommendations array', () => pm.expect(pm.response.json().recommendations).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /search (text match)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?q=morning&sort=_text_match&page=1&pageSize=20",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [
                { "key": "q", "value": "morning" },
                { "key": "sort", "value": "_text_match" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 503', () => pm.expect(pm.response.code).to.be.oneOf([200, 503]));",
                  "if (pm.response.code === 200) {",
                  "  pm.test('results array', () => pm.expect(pm.response.json().results).to.be.an('array'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /search (popular sort + tag filter)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?q=focus&tag=focus&sort=likeCount:desc",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [
                { "key": "q", "value": "focus" },
                { "key": "tag", "value": "focus" },
                { "key": "sort", "value": "likeCount:desc" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Activity",
      "item": [
        {
          "name": "POST /activity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionDurationSeconds\": 1200,\n  \"routinesPlayed\": [\"{{seed_routine_id}}\"],\n  \"tagsEngaged\": [\"focus\", \"morning\"],\n  \"blockTypes\": [\"timer\", \"bell\"]\n}"
            },
            "url": "{{base_url}}/activity"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 202', () => pm.response.to.have.status(202));",
                  "pm.test('accepted true', () => pm.expect(pm.response.json().accepted).to.eql(true));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "DELETE /routines/{id} (published)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/routines/{{published_routine_id}}"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('published_routine_id')) {",
                  "  pm.execution.skipRequest('No published_routine_id from POST /routines');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
